# LogMaster Agent Configuration Example
# Copy this file to config.yaml and edit the values.

devices:
  - name: /dev/ttyUSB0
    baud_rate: 115200
    data_bits: 8
    stop_bits: 1
    parity: none
  # - name: /dev/ttyUSB1
  #   baud_rate: 115200

ollama:
  endpoint: http://localhost:11434
  model: qwen2.5:7b

upload:
  endpoint: http://localhost:8080/api/logs
  api_key: ""
  interval_sec: 10
  batch_size: 100

rules:
  - name: crash
    keywords: [panic, crash, fatal]
    severity: ERROR
    category: crash

  - name: memory_error
    keywords: [OOM, out of memory, memory]
    severity: ERROR
    category: memory

  - name: timeout
    keywords: [timeout, timed out]
    severity: WARN
    category: network

  - name: disk_error
    keywords: [disk, I/O error]
    severity: ERROR
    category: storage